{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "apprenticeship-connector/vacancy-card",
	"version": "1.0.0",
	"title": "Vacancy Card",
	"category": "widgets",
	"icon": "id-alt",
	"description": "Display a single apprenticeship vacancy card. Works standalone and inside the Query Loop block.",
	"keywords": [ "apprenticeship", "vacancy", "card", "job" ],
	"textdomain": "apprenticeship-connector",
	"usesContext": [ "postId", "postType" ],
	"supports": {
		"html": false,
		"align": [ "wide", "full" ],
		"color": { "background": true, "text": true, "link": true },
		"spacing": { "margin": true, "padding": true },
		"typography": { "fontSize": true, "lineHeight": true }
	},
	"attributes": {
		"postId": {
			"type": "number",
			"default": 0
		},
		"showEmployer": {
			"type": "boolean",
			"default": true
		},
		"showLocation": {
			"type": "boolean",
			"default": true
		},
		"showLevel": {
			"type": "boolean",
			"default": true
		},
		"showClosingDate": {
			"type": "boolean",
			"default": true
		},
		"showWage": {
			"type": "boolean",
			"default": true
		},
		"showExcerpt": {
			"type": "boolean",
			"default": true
		},
		"linkToPost": {
			"type": "boolean",
			"default": true
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
